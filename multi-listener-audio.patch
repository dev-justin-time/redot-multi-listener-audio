+void AudioListener3D::_find_listeners(Node *p_node, List<Node *> *r_list) {
+	AudioListener3D *listener = Object::cast_to<AudioListener3D>(p_node);
+	if (listener) {
+		r_list->push_back(p_node);
+	}
+	for (int i = 0; i < p_node->get_child_count(); i++) {
+		_find_listeners(p_node->get_child(i), r_list);
+	}
+}
